# ── MySQL Backend API (for phpMyAdmin database) ───────────────────────────
# Local dev: proxied via Vite (see vite.config.js)
# Production: set to your deployed backend URL (e.g. https://your-backend.onrender.com)
VITE_API_URL=http://localhost:5000

# ── Twilio (for auto SMS/WhatsApp reminders via backend) ──────────────────
# These are used by the Express backend (sms-backend/.env), NOT browser env vars.
# Set them in sms-backend/.env:
#
#   TWILIO_ACCOUNT_SID      (from console.twilio.com)
#   TWILIO_AUTH_TOKEN       (from console.twilio.com)
#   TWILIO_PHONE_NUMBER     e.g. +14155552671  (your Twilio number)
#   TWILIO_MESSAGING_SERVICE_SID  (optional, for messaging service)
#   TWILIO_WHATSAPP_FROM    (optional, for WhatsApp via Twilio)
#
#   DB_HOST=localhost
#   DB_PORT=3306
#   DB_USER=root
#   DB_PASSWORD=
#   DB_NAME_WATERLLAMA=waterllama
#   DB_NAME_SMS=sms_sender